{
  "_comment": "Plinkatron — Default App Configuration. Like Cassian's config.json.",

  "producers": {
    "concept": {
      "default_track_count": 10,
      "min_tracks": 1,
      "max_tracks": 30
    },
    "lyrics": {
      "max_chars": 3000,
      "suno_sanitize": true,
      "auto_suggest_structure": true
    },
    "style": {
      "max_tag_length": 200,
      "auto_sanitize": true
    },
    "generation": {
      "max_retries": 3,
      "poll_interval_ms": 3000,
      "poll_max_attempts": 30,
      "wait_audio": true
    },
    "artwork": {
      "model": "nano-banana-pro",
      "prompt_model": "gemini-2.5-pro",
      "aspect_ratio": "1:1",
      "approval_mode": true,
      "max_regeneration_attempts": 3
    },
    "master": {
      "target_lufs": -14,
      "output_formats": ["wav", "flac", "mp3"],
      "sample_rate": 44100
    },
    "distribute": {
      "platforms": ["tunecore", "distrokid", "cdbaby"],
      "auto_generate_isrc": false
    }
  },

  "gemini": {
    "models": {
      "text": "gemini-2.5-pro",
      "fast": "gemini-2.5-flash"
    },
    "temperature": {
      "creative": 0.8,
      "analytical": 0.3,
      "default": 0.7
    }
  },

  "suno": {
    "api_url": "http://localhost:3000",
    "default_instrumental": false
  }
}
