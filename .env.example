# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://plinkatron:YOUR_PASSWORD@localhost:5432/plinkatron

# ── Session Secret ────────────────────────────────────────────
SESSION_SECRET=generate-a-random-string-here

# ── Google OAuth ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://plinkatron.com/api/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Suno API (self-hosted gcui-art/suno-api) ──────────────────
SUNO_API_URL=http://localhost:3000

# ── Nano Banana Pro (cover art generation) ────────────────────
NANO_BANANA_API_KEY=your-nano-banana-api-key

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3004
